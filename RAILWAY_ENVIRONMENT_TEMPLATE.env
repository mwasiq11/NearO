# Railway Environment Variables Template
# Copy this to Railway dashboard and customize values

# ===== NODE ENVIRONMENT =====
NODE_ENV=production
PORT=3000
API_VERSION=v2

# ===== DATABASE CONFIGURATION =====
# When using Railway's Managed MySQL, these will be auto-populated
# Format for connection string: mysql://user:password@host:port/database

DB_HOST=${MYSQL_PUBLIC_HOST}
DB_PORT=${MYSQL_PORT}
DB_USER=${MYSQL_USER}
DB_PASSWORD=${MYSQL_PASSWORD}
DB_NAME=${MYSQL_DATABASE}

# ===== REDIS CONFIGURATION =====
# When using Railway's Managed Redis, this will be auto-populated

REDIS_URL=${REDIS_URL}
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT}
REDIS_PASSWORD=${REDIS_PASSWORD}

# ===== FRONTEND CONFIGURATION =====
# Update with your actual Railway frontend domain
FRONTEND_URL=https://nearo-frontend.railway.app

# ===== AUTHENTICATION =====
# Generate a strong secret key: openssl rand -hex 32
JWT_SECRET=your-super-secure-jwt-secret-here-change-in-railway

# ===== EMAIL CONFIGURATION (Optional) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password-change-this

# ===== AWS S3 CONFIGURATION (Optional - for file uploads) =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=

# ===== MONITORING & LOGGING =====
# Set to true for production logging
DEBUG=false
LOG_LEVEL=info

# ===== CACHE CONFIGURATION =====
CACHE_TTL=3600

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===== DATABASE POOL CONFIGURATION =====
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ===== OPTIONAL: Read-Write Separation =====
# If you have separate read replicas
# READ_DB_HOST=read-replica.railway.app
# READ_DB_PORT=3306
# READ_DB_USER=${DB_USER}
# READ_DB_PASSWORD=${DB_PASSWORD}
# READ_DB_NAME=${DB_NAME}
