{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "context": "."
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1,
    "sleepApplication": false,
    "triggers": []
  },
  "services": [
    {
      "name": "backend",
      "dockerfile": "./backend/Dockerfile.railway",
      "context": "./backend",
      "port": 3000
    },
    {
      "name": "frontend",
      "dockerfile": "./frontend/Dockerfile.railway",
      "context": "./frontend",
      "port": 8080
    }
  ]
}
